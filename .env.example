# Copiez ce fichier en ".env" et remplissez vos propres valeurs.
# Le fichier ".env" ne doit JAMAIS être partagé ou mis en ligne publiquement.

# Port du serveur local
PORT=3000

# Code secret pour accéder au menu admin
ADMIN_CODE=Paul123

# Configuration de l'envoi d'e-mails (pour répondre aux messages des joueurs)
#
# ⚠️ Si votre site est hébergé sur Render (plan gratuit), le SMTP classique
# (Gmail, Outlook...) ne fonctionnera PAS : Render bloque ces connexions
# sur son offre gratuite. Utilisez EmailJS ou Brevo ci-dessous à la place.
#
# --- Option recommandée : EmailJS (gratuit, aucune adresse postale requise) ---
# 1. Créez un compte gratuit sur https://www.emailjs.com (200 e-mails/mois)
# 2. Email Services > Add New Service > connectez votre Gmail
# 3. Email Templates > créez un template avec les variables {{to_email}}, {{subject}}, {{message}}
# 4. Account > General : copiez votre Public Key
# 5. Account > Security : générez votre Private Key (nécessaire pour l'envoi depuis un serveur)
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=

# --- Option alternative : Brevo (gratuit, demande une adresse postale à l'inscription) ---
# 1. Créez un compte gratuit sur https://www.brevo.com (300 e-mails/jour offerts)
# 2. Vérifiez votre adresse d'envoi (Senders, Domains & Dedicated IPs > Senders)
# 3. Générez une clé API ici : https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
BREVO_SENDER_EMAIL=votre.adresse@gmail.com

# --- Option alternative : SMTP classique (fonctionne en local, pas sur Render gratuit) ---
# Exemple avec une adresse Gmail :
# 1. Activez la validation en 2 étapes sur le compte Google
# 2. Créez un "mot de passe d'application" ici : https://myaccount.google.com/apppasswords
# 3. Utilisez ce mot de passe d'application ci-dessous (pas votre vrai mot de passe)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=votre.adresse@gmail.com
SMTP_PASS=votre_mot_de_passe_application
SMTP_FROM="Vestiges - Développeur" <votre.adresse@gmail.com>
