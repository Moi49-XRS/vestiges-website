# Copiez ce fichier en ".env" et remplissez vos propres valeurs.
# Le fichier ".env" ne doit JAMAIS être partagé ou mis en ligne publiquement.

# Port du serveur local
PORT=3000

# Code secret pour accéder au menu admin
ADMIN_CODE=Paul123

# Configuration de l'envoi d'e-mails (pour répondre aux messages des joueurs)
# Exemple avec une adresse Gmail :
# 1. Activez la validation en 2 étapes sur le compte Google
# 2. Créez un "mot de passe d'application" ici : https://myaccount.google.com/apppasswords
# 3. Utilisez ce mot de passe d'application ci-dessous (pas votre vrai mot de passe)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=votre.adresse@gmail.com
SMTP_PASS=votre_mot_de_passe_application
SMTP_FROM="Vestiges - Développeur" <votre.adresse@gmail.com>
